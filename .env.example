# OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# LangSmith (for tracing)
LANGSMITH_TRACING_V2=true
LANGSMITH_API_KEY=your_langchain_api_key
LANGSMITH_PROJECT=your_langchain_project_name

# Pinecone (required for RAG)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=nutriguide-app-knowledge

# Database (required for backend)
# Docker: use host.docker.internal to reach host PostgreSQL from containers
# Local (backend outside Docker): use localhost
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/nutriguide

# USDA FoodData Central (for food search)
# Get key at https://api.data.gov/signup
USDA_FDC_API_KEY=your-data-gov-api-key

# Internal API key (backend + agent; generate with: openssl rand -hex 32)
INTERNAL_API_KEY=your-internal-api-key

# Backend URL (agent uses this to fetch profiles; use http://backend:3001 in Docker)
BACKEND_URL=http://localhost:3001

# Backend (required)
PORT=3001
AGENT_URL=http://localhost:8000

# AI Agent (required)
AGENT_PORT=8000
